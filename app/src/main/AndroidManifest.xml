<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ============ NFC ============ -->
    <uses-permission android:name="android.permission.NFC" />
    <uses-feature
        android:name="android.hardware.nfc"
        android:required="true" />

    <!-- ============ 蓝牙（Android 12+ 免定位）============ -->
    <!-- 扫描仅用于连接已知 MAC 的门禁设备，声明 neverForLocation，不推断位置 -->
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="s" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_CONNECT"
        tools:targetApi="s" />

    <!-- 兼容 Android 11 及以下的旧蓝牙权限 -->
    <uses-permission
        android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_ADMIN"
        android:maxSdkVersion="30" />

    <!--
      定位权限（仅 Android 8～11 需要）：这些版本 BLE 扫描必须授予 ACCESS_FINE_LOCATION
      且定位开关开着，否则扫不到任何设备（minSdk=26 覆盖此区间）。Android 12+ 走
      BLUETOOTH_SCAN(neverForLocation)，不再需要定位权限，故 maxSdkVersion=30。
    -->
    <uses-permission
        android:name="android.permission.ACCESS_FINE_LOCATION"
        android:maxSdkVersion="30" />

    <uses-feature
        android:name="android.hardware.bluetooth_le"
        android:required="true" />

    <application
        android:name=".PinganApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.PinganBaiyun">

        <!--
          NfcRouterActivity：碰卡冷启动落地页。
          NDEF_DISCOVERED + 自定义 MIME 精确匹配，APP 未启动也能被系统直接唤起（不弹选择框）。
          singleTask + onNewIntent 作为前台/后台统一入口。
        -->
        <activity
            android:name=".ui.NfcRouterActivity"
            android:exported="true"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.nfc.action.NDEF_DISCOVERED" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/vnd.pinganbaiyun.door" />
            </intent-filter>
        </activity>

        <!-- 运行流程：读卡成功 → BLE 握手开门（原型 N/C 段） -->
        <activity
            android:name=".ui.unlock.UnlockActivity"
            android:exported="false" />

        <!-- 蓝牙信息维护 · 新增/编辑（原型 M-02） -->
        <activity
            android:name=".ui.devices.edit.DeviceEditActivity"
            android:exported="false" />

        <!-- NFC 写卡（原型 W 段），运行时前台调度拿 Tag -->
        <activity
            android:name=".ui.write.WriteCardActivity"
            android:exported="false"
            android:launchMode="singleTop" />

        <!-- 权限申请引导（原型 P-01） -->
        <activity
            android:name=".ui.permission.PermissionActivity"
            android:exported="false" />

    </application>
</manifest>
