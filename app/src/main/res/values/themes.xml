<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- 强制浅色（原型手机内屏为浅底品牌蓝），避免深色模式反色影响可读性 -->
    <style name="Theme.PinganBaiyun" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/brand_on_primary</item>
        <item name="colorSecondary">@color/door</item>
        <item name="android:colorBackground">@color/paper</item>
        <item name="android:windowBackground">@color/paper</item>
        <item name="android:statusBarColor">@color/paper</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/card</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
    </style>

    <style name="Theme.PinganBaiyun.Splash" parent="Theme.PinganBaiyun" />

    <!-- 底部弹层（P-02/P-03）圆角 -->
    <style name="Theme.PinganBaiyun.BottomSheet" parent="Theme.Material3.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/PinganBottomSheet</item>
    </style>
    <style name="PinganBottomSheet" parent="Widget.Material3.BottomSheet.Modal">
        <item name="shapeAppearanceOverlay">@style/PinganBottomSheetShape</item>
    </style>
    <style name="PinganBottomSheetShape">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
    </style>
</resources>
