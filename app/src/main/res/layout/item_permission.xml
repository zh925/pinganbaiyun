<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="14dp"
    android:baselineAligned="false">

    <FrameLayout
        android:id="@+id/permIconBox"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:background="@drawable/bg_iconbox_nfc">

        <ImageView
            android:id="@+id/permIcon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_nfc"
            android:contentDescription="@null"
            app:tint="@color/white" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginHorizontal="13dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/permName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/brand_900"
            android:textSize="13.5sp"
            android:textStyle="bold"
            tools:text="NFC 近场通信" />

        <TextView
            android:id="@+id/permDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/muted"
            android:textSize="11.5sp"
            android:lineSpacingMultiplier="1.35"
            tools:text="读取 / 写入门禁卡，并支持碰卡冷启动唤起" />
    </LinearLayout>

    <TextView
        android:id="@+id/permState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="10dp"
        android:paddingVertical="5dp"
        android:background="@drawable/bg_pill_ok"
        android:textColor="@color/ok"
        android:textSize="11sp"
        android:textStyle="bold"
        tools:text="已就绪" />
</LinearLayout>
