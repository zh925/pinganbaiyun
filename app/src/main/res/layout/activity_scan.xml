<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/paper"
    android:fitsSystemWindows="true">

    <include
        android:id="@+id/appbar"
        layout="@layout/appbar" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- B-01 扫描中 -->
        <LinearLayout
            android:id="@+id/scanLoadingSection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="18dp">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:indeterminate="true"
                app:indicatorSize="72dp"
                app:trackThickness="6dp"
                app:indicatorColor="@color/bt" />

            <TextView
                style="@style/Text.Lead"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/scan_lead" />

            <TextView
                android:id="@+id/scanCount"
                style="@style/Text.Desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                tools:text="已发现 3 个 BLE 设备" />
        </LinearLayout>

        <!-- B-02 设备列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/scanList"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingHorizontal="18dp"
            android:paddingTop="8dp"
            android:visibility="gone"
            tools:listitem="@layout/item_scan_device" />

        <!-- B-03 空态 -->
        <LinearLayout
            android:id="@+id/scanEmptySection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="40dp"
            android:visibility="gone"
            tools:visibility="gone">

            <FrameLayout
                android:layout_width="104dp"
                android:layout_height="104dp"
                android:background="@drawable/bg_circle_warn">

                <ImageView
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_search"
                    android:contentDescription="@null"
                    app:tint="@color/white" />
            </FrameLayout>

            <TextView
                style="@style/Text.Lead"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/scan_empty_lead" />

            <TextView
                style="@style/Text.Desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/scan_empty_desc" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="16dp"
                android:padding="12dp"
                android:background="@drawable/bg_alert_warn">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_warning"
                    android:contentDescription="@null"
                    app:tint="@color/alert_warn_fg" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:text="@string/scan_empty_hint"
                    android:textColor="@color/alert_warn_fg"
                    android:textSize="12.5sp"
                    android:lineSpacingMultiplier="1.4" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="18dp"
        android:paddingTop="8dp"
        android:paddingBottom="18dp">

        <LinearLayout
            android:id="@+id/scanListHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp"
            android:padding="12dp"
            android:background="@drawable/bg_alert_info"
            android:visibility="gone"
            tools:visibility="visible">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_info"
                android:contentDescription="@null"
                app:tint="@color/alert_info_fg" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="@string/scan_hint_matched"
                android:textColor="@color/alert_info_fg"
                android:textSize="12.5sp"
                android:lineSpacingMultiplier="1.4" />
        </LinearLayout>

        <Button
            android:id="@+id/scanBtnPrimary"
            style="@style/PinganButton"
            android:background="@drawable/bg_button_bt"
            android:text="@string/scan_stop"
            tools:ignore="ButtonStyle" />

        <Button
            android:id="@+id/scanBtnSecondary"
            style="@style/PinganButton.Ghost"
            android:layout_marginTop="9dp"
            android:text="@string/scan_back_tap"
            android:visibility="gone"
            tools:visibility="visible"
            tools:ignore="ButtonStyle" />
    </LinearLayout>
</LinearLayout>
