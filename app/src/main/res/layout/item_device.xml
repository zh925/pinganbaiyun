<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_card"
    android:padding="13dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:baselineAligned="false">

        <FrameLayout
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/bg_iconbox_door">

            <ImageView
                android:layout_width="19dp"
                android:layout_height="19dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_door"
                android:contentDescription="@null"
                app:tint="@color/white" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="11dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/deviceName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_900"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="1栋大堂门" />

            <TextView
                android:id="@+id/deviceDefaultBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_pill_door"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="@string/device_default_badge"
                android:textColor="@color/door"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/deviceMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:fontFamily="monospace"
                android:textColor="@color/muted"
                android:textSize="10sp"
                tools:text="BY-Lock-08 · C4:2F:90:AB:07:11" />
        </LinearLayout>

        <ImageView
            android:id="@+id/deviceDelete"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:padding="7dp"
            android:src="@drawable/ic_close"
            android:contentDescription="@string/device_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/muted" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="11dp"
        android:background="@color/line" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/deviceDefault"
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:layout_marginTop="11dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text="@string/device_set_default"
        android:textColor="@color/brand_700"
        android:textSize="12sp"
        android:textStyle="bold"
        android:background="@drawable/bg_button_ghost"
        android:stateListAnimator="@null"
        tools:ignore="ButtonStyle" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="11dp"
        android:baselineAligned="false">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/deviceOpen"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:layout_marginEnd="3dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/device_open"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_door"
            android:stateListAnimator="@null"
            tools:ignore="ButtonStyle" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/deviceWrite"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="3dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/device_write_card"
            android:textColor="@color/nfc_dark"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_nfc"
            android:stateListAnimator="@null"
            tools:ignore="ButtonStyle" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/deviceEdit"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:layout_marginStart="3dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/device_edit"
            android:textColor="@color/brand_700"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_ghost"
            android:stateListAnimator="@null"
            tools:ignore="ButtonStyle" />
    </LinearLayout>

    <!-- 行内开门反馈（成功 / 失败），默认隐藏 -->
    <LinearLayout
        android:id="@+id/deviceHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="9dp"
        android:padding="9dp"
        android:visibility="gone"
        android:background="@drawable/bg_alert_ok"
        tools:visibility="visible">

        <ImageView
            android:id="@+id/deviceHintIcon"
            android:layout_width="15dp"
            android:layout_height="15dp"
            android:src="@drawable/ic_check"
            android:contentDescription="@null"
            app:tint="@color/alert_ok_fg" />

        <TextView
            android:id="@+id/deviceHintText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:textColor="@color/alert_ok_fg"
            android:textSize="11.5sp"
            android:lineSpacingMultiplier="1.3"
            tools:text="门已打开（回执 00）· 已震动提示" />
    </LinearLayout>
</LinearLayout>
